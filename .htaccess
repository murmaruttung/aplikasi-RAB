# Aktifkan Rewrite Engine
RewriteEngine On

# Jangan tampilkan isi folder
Options -Indexes

# Set default charset
AddDefaultCharset UTF-8

# Izinkan akses ke assets
<FilesMatch "\.(css|js|png|jpg|jpeg|gif|ico|svg)$">
    Require all granted
</FilesMatch>

# Lindungi file konfigurasi
<FilesMatch "^(config\.php|database\.php|security\.php)$">
    Require all denied
</FilesMatch>
